component TabView {
    #[param]
    tabs: Vec<std::rc::Rc<T>>,

    #[param]
    key: Box<dyn Fn(&std::rc::Rc<T>) -> usize>,

    #[param]
    render_label: Box<dyn Fn(&std::rc::Rc<T>) -> String>,

    #[param]
    render_content: Box<dyn Fn(&std::rc::Rc<T>) -> AnyView>,

    #[param]
    selected: usize,

    #[param]
    closable: bool,

    on_select: Box<dyn Fn(usize)>,

    on_close: Box<dyn Fn(usize)>,
}
