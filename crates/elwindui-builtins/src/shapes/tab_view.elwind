component TabView {
    #[param]
    tabs: Vec<std::rc::Rc<T>>,

    #[param]
    key: fn(&std::rc::Rc<T>) -> usize,

    #[param]
    render_label: fn(&std::rc::Rc<T>) -> String,

    #[param]
    render_content: fn(&std::rc::Rc<T>) -> AnyView,

    #[param]
    selected: usize,

    #[param]
    closable: bool,

    on_select: fn(usize),

    on_close: fn(usize),
}
